# Base URL of the running FastAPI backend
BASE_URL=http://localhost:8000

# Must match SECRET_KEY in backend/.env — used to craft expired JWTs for TC-012
SECRET_KEY=your-secret-key-here

# Admin credentials for TC-009 (admin role test)
# Create this user via the admin seed script or DB insert
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=AdminPass123!
